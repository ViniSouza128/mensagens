# Mensagens — variáveis de ambiente
# Copie este arquivo para .env e ajuste conforme necessário.

# Segredo usado para assinar tokens de sessão (JWT). Use um valor longo e aleatório em produção.
AUTH_SECRET=change-this-to-a-long-random-string-min-32-chars

# Domínio de cookie (vazio = padrão do navegador)
AUTH_COOKIE_DOMAIN=

# Tempo de vida do token de sessão em segundos (padrão: 30 dias)
AUTH_TTL_SECONDS=2592000

# Diretório de dados do SQLite (relativo à raiz do projeto)
DATA_DIR=data

# Diretório de uploads locais (relativo à raiz do projeto)
UPLOADS_DIR=uploads

# Diretório de logs (relativo à raiz do projeto)
LOGS_DIR=logs

# Credenciais do admin inicial (usadas pelo seed na primeira execução).
# Altere ADMIN_PASSWORD antes de subir em produção!
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@mensagens.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# Limites de upload (em bytes). Padrão: fotos 80 MB, vídeos 320 MB, docs 2 GB.
UPLOAD_MAX_PHOTO=83886080
UPLOAD_MAX_VIDEO=335544320
UPLOAD_MAX_FILE=2147483648

# Configurações de link preview
# MAX_BYTES: quantidade máxima de HTML baixada por preview (padrão 512 KB)
LINK_PREVIEW_TIMEOUT_MS=5000
LINK_PREVIEW_MAX_BYTES=524288
